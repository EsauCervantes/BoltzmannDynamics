Cell[TextData[{
 "The ratio between the observed DM relic abundance and the model\
\[CloseCurlyQuote]s prediction ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      SubscriptBox["Y", "\[Phi]"], "(", "xf", ")"}], "/", 
     SubscriptBox["Y", "obs"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "9d5727df-fe00-4c97-a53d-c1fce099488c"],
 ") is the last output of the cBEsolver routine"
}], "Text",
 CellChangeTimes->{{3.986619496650751*^9, 3.9866195614137278`*^9}, {
  3.986619602799985*^9, 
  3.9866196773551617`*^9}},ExpressionUUID->"39cae475-2cce-437e-85b3-\
6e0cb45e56d1"],

